<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Link Analytics</title>

<style>
body {
    background: #f4f6f9;
    font-family: Arial;
    padding: 20px;
}

.dashboard {
    max-width: 1200px;
    margin: auto;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    margin-bottom: 20px;
}

h2 {
    margin-bottom: 10px;
}

/* Stats cards */
.stats {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
}

.stat-box {
    flex: 1;
    background: #2563eb;
    color: white;
    padding: 20px;
    border-radius: 10px;
    text-align: center;
}

/* Table */
table {
    width: 100%;
    border-collapse: collapse;
}

thead {
    background: #2563eb;
    color: white;
}

td, th {
    padding: 10px;
}

tbody tr:hover {
    background: #eef2ff;
}
</style>

</head>

<body>

<div class="dashboard">

    <div class="card">
        <h2>Analytics for: <%= link.short_code %></h2>
        <p><strong>Original URL:</strong> <%= link.original_url %></p>
        <p><strong>Short URL:</strong> <%= link.short_url %></p>
    </div>

    <div class="stats">
        <div class="stat-box">
            <h3>Total Clicks</h3>
            <h1><%= link.count %></h1>
        </div>
    </div>

    <div class="card">
        <h2>All Click Logs</h2>

        <table>
            <thead>
                <tr>
                    <th>IP</th>
                    <th>Device</th>
                    <th>Browser</th>
                    <th>Time</th>
                </tr>
            </thead>

            <tbody>
                <% analytics.forEach(a => { %>
                <tr>
                    <td><%= a.ip %></td>
                    <td><%= a.device %></td>
                    <td><%= a.browser %></td>
                    <td><%= a.accessed_at %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

</div>

</body>
</html>